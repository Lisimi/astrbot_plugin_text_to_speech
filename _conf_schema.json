{
  "base_url": {
    "type": "string",
    "default": "http://192.168.0.105:9880",
    "description": "SoVITS API 服务地址"
  },
  "max_text_length": {
    "type": "int",
    "default": 80,
    "description": "生成语音的最大文本长度",
    "slider": {
      "min": 50,
      "max": 100,
      "step": 1
    }
  },
  "min_text_length": {
    "type": "int",
    "default": 10,
    "description": "生成语音的最小文本长度",
    "slider": {
      "min": 1,
      "max": 49,
      "step": 1
    }
  },
  "clean_patterns": {
    "type": "list",
    "default": [
      "\\(.*?\\)",
      "\\[.*?\\]",
      "\\<.*?\\>",
      "\\*.*?\\*"
    ],
    "description": "需要过滤的正则表达式列表"
  },
  "sovits_model": {
    "type": "string",
    "default": "SoVITS_weights_v3/Qingyi_e2_s46_l32.pth",
    "description": "SoVITS 模型路径"
  },
  "gpt_model": {
    "type": "string",
    "default": "GPT_weights_v3/Qingyi-e10.ckpt",
    "description": "GPT 模型路径"
  },
  "ref_audio": {
    "type": "string",
    "default": "ref_audio/Qingyi.wav_0001504320_0001702080.wav",
    "description": "参考音频路径（本地路径）"
  },
  "prompt_text": {
    "type": "string",
    "default": "嗯。如果不是因为店长深谙电影知识，我可能会错过这个细节也未可知。",
    "description": "参考音频对应的文本"
  }
}
